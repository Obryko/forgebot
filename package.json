{
	"name": "forgebot",
	"type": "module",
	"private": true,
	"scripts": {
		"prepare": "lefthook install",
		"worker:dev": "bun --filter=@forgebot/worker run dev",
		"worker:start": "bun --filter=@forgebot/worker run start",
		"lint": "biome check .",
		"format": "bun run format:staged .",
		"format:staged": "biome check --write --no-errors-on-unmatched",
		"test": "bun run test:unit && bun run test:integration",
		"test:unit": "bun test ./packages ./apps/*/src",
		"test:integration": "bun test ./apps/*/test/integration",
		"typecheck": "tsc --noEmit",
		"check": "bun run typecheck && bun run test:unit && bun run test:integration && bun run lint"
	},
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*",
			"packages/plugins/*",
			"packages/ai/*"
		],
		"catalog": {},
		"catalogs": {}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@types/bun": "^1.3.14",
		"lefthook": "^2.1.10",
		"typescript": "^7.0.2"
	}
}
