{
  "name": "forgebot",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "lint": "biome check .",
    "format": "bun run format:staged .",
    "format:staged": "biome check --write",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test ./packages ./apps/*/src",
    "test:integration": "bun test ./apps/*/test/integration",
    "typecheck": "tsc --noEmit"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/plugins/*",
      "packages/ai/*"
    ],
    "catalog": {},
    "catalogs": {}
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "latest",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3"
  }
}
