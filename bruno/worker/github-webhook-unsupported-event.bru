meta {
  name: GitHub Webhook - Unsupported Event
  type: http
  seq: 3
}

post {
  url: http://localhost:3000/webhooks/github
  body: json
  auth: none
}

headers {
  content-type: application/json
  x-github-event: issues
}

body:json {
  {
    "action": "opened",
    "repository": {
      "full_name": "test/repo"
    }
  }
}

tests {
  test("should return 204", function() {
    expect(res.status).to.equal(204);
  });
}
