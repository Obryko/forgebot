meta {
  name: GitHub Webhook - PR Opened
  type: http
  seq: 2
}

post {
  url: http://localhost:3000/webhooks/github
  body: json
  auth: none
}

headers {
  content-type: application/json
  x-github-event: pull_request
}

body:json {
  {
    "action": "opened",
    "pull_request": {
      "number": 1
    },
    "repository": {
      "full_name": "test/repo"
    }
  }
}

tests {
  test("should return 202", function() {
    expect(res.status).to.equal(202);
  });
}
